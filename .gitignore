# --- Java / Maven ---
# Ignores the 'target' folder anywhere in the project (including inside oop_logistics_projects)
target/
*.class
logs/
*.log
# Ignore SQLite databases
*.db
*.sqlite
*.sqlite3
logistics_data.db

# --- Python ---
# Ignores __pycache__ directories anywhere (including python_model and its subfolders)
__pycache__/
*.py[cod]
*$py.class

# --- IDE Settings (Optional but recommended) ---
.vscode/
.idea/
.classpath
.project
*.settings/
# Model artifacts
*.npy
*.pt
*.joblib